<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.LabelReader" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:navigationBarColor">#1A1A1A</item>
        <item name="colorPrimary">#FFD700</item>
        <item name="colorPrimaryVariant">#1A1A1A</item>
        <item name="colorOnPrimary">#000000</item>
    </style>

    <!-- Dark theme (default) -->
    <style name="Theme.LabelReader.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:navigationBarColor">#1A1A1A</item>
        <item name="colorPrimary">#FFD700</item>
        <item name="colorPrimaryVariant">#1A1A1A</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Light theme -->
    <style name="Theme.LabelReader.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">#F5F5F5</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:statusBarColor">#EEEEEE</item>
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryVariant">#EEEEEE</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Accessibility theme — max contrast -->
    <style name="Theme.LabelReader.Accessibility" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="colorPrimary">#FFFF00</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

</resources>